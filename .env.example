# ============================================================
# N8N DevSecOps Starter - Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit .env to git (it's in .gitignore)
# ============================================================

# --- N8N Access Credentials ---
# Change these from the defaults before running!
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_use_strong_password

# --- Encryption Key ---
# Generate a secure key with: openssl rand -hex 32
# This encrypts credentials stored inside N8N
N8N_ENCRYPTION_KEY=replace_with_output_of_openssl_rand_hex_32

# --- GitHub ---
# Create a token at: https://github.com/settings/tokens
# Required scopes: public_repo (read only is sufficient)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=repository_to_monitor

# --- Slack ---
# Create a webhook at: https://api.slack.com/apps
# Docs: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
